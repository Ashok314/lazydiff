{
  "manifest_version": 3,
  "name": "lazydiff",
  "description": "Hide unwanted GitHub PR files with negative filters and see the filtered diff size.",
  "version": "0.1.0",
  "homepage_url": "https://ashok314.github.io/lazydiff/",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "lazydiff",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/pull/*"],
      "js": ["dist/types.js", "dist/core.js", "dist/storage.js", "dist/github.js", "dist/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ]
}
